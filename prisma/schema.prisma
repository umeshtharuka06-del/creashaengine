// engine-royal — data model.
//
// EXACT COPY of the website's prisma/schema.prisma. The engine shares the same
// MongoDB database as the website; this copy exists only so the engine can
// generate its own Prisma client and run independently. Keep it in sync with
// the website schema — do not diverge the models.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ───────────────────────────── Users & auth ─────────────────────────────

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  email        String   @unique
  username     String   @unique
  passwordHash String
  isAdmin      Boolean  @default(false)
  isBanned     Boolean  @default(false)
  clientSeed   String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  wallet    Wallet?
  bets      Bet[]
  txns      Transaction[]
  auditLogs AuditLog[]
}

// ───────────────────────────── Wallet & ledger ──────────────────────────

model Wallet {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  balance   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  type         String
  amount       Int
  balanceAfter Int
  ref          String?
  meta         String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ───────────────────────────── Games ────────────────────────────────────

model GameRound {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  game           String    // COLOR | CRASH | NUMBER
  period         BigInt
  state          String    @default("BETTING") // BETTING | RUNNING | SETTLED
  serverSeed     String
  serverSeedHash String
  result         String?
  forcedResult   String?
  startAt        DateTime
  lockAt         DateTime
  settleAt       DateTime
  settledAt      DateTime?
  createdAt      DateTime  @default(now())

  bets Bet[]

  @@unique([game, period])
  @@index([game, state])
}

model Bet {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  roundId   String   @db.ObjectId
  game      String
  amount    Int
  selection String
  cashoutX  Int?
  status    String   @default("PENDING")
  payout    Int      @default(0)
  createdAt DateTime @default(now())

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  round GameRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([roundId])
}

// ───────────────────────────── Platform ─────────────────────────────────

model Announcement {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  body      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Setting {
  key       String   @id @map("_id")
  value     String
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  action    String
  detail    String?
  ip        String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}
