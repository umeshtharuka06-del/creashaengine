// Royal 1 — data model (MongoDB)
//
// Uses Prisma's MongoDB provider. IMPORTANT: multi-document transactions
// (used by the wallet/betting/settlement code) require a REPLICA SET.
// MongoDB Atlas provides this by default. A standalone local `mongod` does
// not — run Atlas, or a local replica set, for betting to work.

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; "rhel-openssl-3.0.x" is the Vercel/AWS Lambda
  // runtime so the query engine binary is present in serverless functions.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ───────────────────────────── Users & auth ─────────────────────────────

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  email        String   @unique
  username     String   @unique
  passwordHash String
  isAdmin      Boolean  @default(false)
  isBanned     Boolean  @default(false)
  // per-user provably-fair client seed (rotatable)
  clientSeed   String   @default("")
  // Referral: the userId of the referrer, set ONCE at registration and never
  // changed (so an existing user can never be reassigned). Null = organic signup.
  referredBy   String?  @db.ObjectId
  // The deposit wallet currently LOCKED to this user. Assigned at random from the
  // active pool on the first deposit visit and held (across refresh/logout/login)
  // until a deposit is APPROVED, at which point it is cleared so the next request
  // rotates to a new random wallet.
  assignedWalletId String? @db.ObjectId
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  wallet    Wallet?
  bets      Bet[]
  txns      Transaction[]
  auditLogs AuditLog[]
}

// ───────────────────────────── Wallet & ledger ──────────────────────────

model Wallet {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  // balance is stored in integer "coin cents" (1 coin = 100) to avoid float drift
  balance   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Every balance change is recorded as an immutable ledger row.
model Transaction {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  type         String   // SIGNUP_BONUS | BET | PAYOUT | DEPOSIT | WITHDRAWAL | ADMIN_CREDIT | ADMIN_DEBIT
  amount       Int      // signed coin-cents, +credit / -debit
  balanceAfter Int
  ref          String?  // related bet id / external txn ref
  meta         String?  // JSON string
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ───────────────────────────── Games ────────────────────────────────────

model GameRound {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  game           String    // COLOR | CRASH | NUMBER
  period         BigInt    // monotonic round number
  state          String    @default("BETTING") // BETTING | RUNNING | SETTLED
  // provably fair
  serverSeed     String
  serverSeedHash String
  // outcome (game-specific, JSON encoded)
  result         String?
  // Admin override set from the panel BEFORE settlement. JSON, game-specific:
  //   COLOR  → {"color":"RED"} or {"digit":3}
  //   NUMBER → {"digit":7}
  // When present, the prediction engine uses this instead of its own decision.
  forcedResult   String?
  startAt        DateTime
  lockAt         DateTime // betting closes
  settleAt       DateTime
  settledAt      DateTime?
  createdAt      DateTime  @default(now())

  bets Bet[]

  @@unique([game, period])
  @@index([game, state])
}

model Bet {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  roundId   String   @db.ObjectId
  game      String   // COLOR | CRASH
  amount    Int      // coin-cents staked (gross — what the user is debited)
  // House fee taken on the stake. effectiveBet = amount - feeAmount and is what
  // settlement uses to compute payouts. Legacy rows have feeAmount 0 / effectiveBet 0.
  feeAmount    Int   @default(0)
  effectiveBet Int   @default(0)
  // COLOR: selection = "RED" | "GREEN" | "VIOLET"
  // CRASH: selection = autoCashout multiplier x100 (e.g. "200" = 2.00x), "0" = manual
  selection String
  // CRASH manual/auto cashout multiplier achieved x100, null if not cashed
  cashoutX  Int?
  status    String   @default("PENDING") // PENDING | WON | LOST | CASHED
  payout    Int      @default(0) // coin-cents returned (0 if lost)
  createdAt DateTime @default(now())

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  round GameRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([roundId])
}

// ───────────────────────────── Platform ─────────────────────────────────

model Announcement {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  body      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// House fee taken on every bet (revenue ledger, separate from the player wallet
// ledger). One row per fee charged, so the admin dashboard can total fee income
// over any time window.
model HouseTransaction {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  betId     String   @db.ObjectId
  userId    String   @db.ObjectId
  game      String
  fee       Int      // coin-cents taken as house fee
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ───────────────────────── Crypto (TRC20 USDT) ──────────────────────────
//
// Deposit wallets are admin-managed. Each user is randomly assigned ONE active
// wallet (locked until their deposit completes). A deposit is a user-initiated
// REQUEST: the user sends USDT to the assigned wallet then clicks "I Have Paid".
// The TronGrid poller then watches that wallet and matches the incoming transfer
// by amount, auto-crediting on confirmation; the admin can also approve/reject.

// Admin-managed pool of TRC20 receive addresses users are randomly assigned.
model DepositWallet {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String   // human label, e.g. "Wallet 1"
  address      String   // TRC20 receive address
  network      String   @default("TRC20")
  active       Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active, displayOrder])
}

// A user-initiated deposit request against an assigned wallet.
// walletId/toAddress are optional only to tolerate legacy on-chain deposit rows
// from the previous auto-detect system on this schemaless DB — the new request
// flow always populates them.
model Deposit {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  userId        String    @db.ObjectId
  walletId      String?   @db.ObjectId // the DepositWallet assigned at request time
  toAddress     String?             // snapshot of the assigned wallet address
  network       String    @default("TRC20")
  amountUsdt    Float               // amount the user says they sent
  coins         Int       @default(0) // coin-cents credited on approval
  // On-chain match (filled by the poller, optional if approved manually).
  txid          String?             // on-chain transaction id (deduped in code)
  fromAddress   String?
  confirmations Int       @default(0)
  // PENDING (awaiting verification) | APPROVED (credited) | REJECTED
  status        String    @default("PENDING")
  adminId       String?   @db.ObjectId // admin who approved/rejected
  note          String?
  createdAt     DateTime  @default(now())
  processedAt   DateTime?
  creditedAt    DateTime?

  @@index([userId, createdAt])
  @@index([status])
  @@index([walletId, status])
}

model Withdrawal {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String    @db.ObjectId
  address     String              // TRC20 destination address
  coins       Int                 // coin-cents debited (held at request time)
  usdt        Float               // coins / conversion rate
  feeUsdt     Float
  receiveUsdt Float               // usdt - fee (what the user is sent)
  // PENDING | APPROVED | COMPLETED | REJECTED
  status      String    @default("PENDING")
  txid        String?             // set when the admin marks it COMPLETED
  adminId     String?   @db.ObjectId
  note        String?
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  @@index([userId, createdAt])
  @@index([status])
}

// Key/value settings editable from the admin panel (e.g. signup bonus).
// The natural string key is used directly as the Mongo _id.
model Setting {
  key       String   @id @map("_id")
  value     String
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  action    String
  detail    String?  // JSON string
  ip        String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}
